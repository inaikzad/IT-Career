@model CreateDiaryEntryViewModel

@{
    ViewData["Title"] = "Create Diary Entry";
}

<h2>Create Diary Entry</h2>

<form asp-action="Create" asp-controller="DiaryEntry" method="post">
    <div class="form-group">
        <label asp-for="Entry.Description" class="control-label"></label>
        <textarea asp-for="Entry.Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Entry.Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Entry.CategoryId" class="control-label">Category</label>
        <select asp-for="Entry.CategoryId" class="form-control">
            <option value="">-- Select Category --</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category.Id">@category.Type</option>
            }
        </select>
    </div>

    <div class="form-group">
        <div class="form-check mt-3">
            <input asp-for="Entry.IsPrivate" class="form-check-input" type="checkbox" />
            <label asp-for="Entry.IsPrivate" class="form-check-label">Make this entry private</label>
        </div>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="GetAll" asp-controller="DiaryEntry" class="btn btn-secondary">Cancel</a>
    </div>
</form>