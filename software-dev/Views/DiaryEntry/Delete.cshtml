@model GetDiaryEntryViewModel

@{
    ViewData["Title"] = "Delete Diary Entry";
}

<h2>Delete Diary Entry</h2>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this diary entry?</h4>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Written by</dt>
            <dd class="col-sm-9">@Model.DiaristFirstName @Model.DiaristLastName</dd>
        </dl>

        <form asp-action="DeleteDiaryEntry" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="GetAll" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>