@{
    ViewData["Title"] = "My Online Diary";
}

<section class="text-center mt-5">
    <h1 class="display-4">Welcome to Your Personal Diary</h1>
    <p class="lead mt-3">A safe space to write, reflect, and remember.</p>
    <p>Capture your thoughts. Record your memories. One entry at a time.</p>
    <p>You can choose to make your entry private or public so you can share experiences with others!</p>
    
    <div class="mt-4">
        <a class="btn btn-primary btn-lg" href="/DiaryEntry/GetAll">View All Entries</a>
        <a class="btn btn-outline-secondary btn-lg" href="/DiaryEntry/Create">New Entry</a>
    </div>
</section>

